# Dependencies
node_modules/
mcp-packages/node_modules/

# Build output
dist/

# User data dirs (contain API keys, tokens, session data)
.artemis/
.mylaude/

# Plugin source bundled separately — included via npm files field
# plugins/ intentionally NOT ignored (bundled with CLI)

# Secrets & environment
.env
.env.*
*.env
npmrc
.npmrc

# Logs & temp
*.log
*.tmp
*.bak
*.backup
*.orig
.DS_Store
Thumbs.db

# Saga A/B debug captures (may contain real user paths and reference media)
.artemis-tmp/

# Test artifacts
test-output/
test-*/
coverage/

# Saga long-video test outputs (provider-generated content, large,
# privacy-sensitive, never published).
generated-media/

# Skill vendor dirs
skills/web-spider/vendor/

# Dev scripts used during setup (not for end users)
/tmp/
scripts/install_*.py
scripts/fetch_*.py

# Top-level docs/ are local-only (not packaged, not tracked); src/docs and dist/docs are code
/docs/
